#!/bin/bash
set -euo pipefail

script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)"
dotfiles_dir="$(cd -- "${script_dir}/.." && pwd -P)"
darwin_rebuild="/run/current-system/sw/bin/darwin-rebuild"

if [[ ! -x "${darwin_rebuild}" ]]; then
  printf 'darwin-rebuild is not available at %s\n' "${darwin_rebuild}" >&2
  exit 1
fi

# Keep the Mac awake while missing llm-agents.nix source packages build.
# darwin-rebuild does not accept --accept-flake-config; pass it as a Nix
# --option. sudo runs as root (trusted-users), so flake nixConfig can enable
# cache.numtide.com for this build before nix.custom.conf is activated.
exec /usr/bin/caffeinate -i /usr/bin/sudo "${darwin_rebuild}" switch \
  --flake "${dotfiles_dir}#macbook" \
  --option accept-flake-config true \
  --print-build-logs
